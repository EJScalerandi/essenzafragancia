# server/.env.example
PORT=4000

# MercadoPago credentials (from your MercadoPago developer dashboard)
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# test | prod
MP_MODE=test

# IMPORTANT:
# MercadoPago Checkout Pro requires HTTPS URLs for back_urls/notification_url in many cases.
# Use ngrok (or similar) and put your public https URL here:
FRONTEND_BASE_URL=https://xxxx.ngrok-free.app

# Optional - Webhook URL (should be HTTPS)
MP_WEBHOOK_URL=https://xxxx.ngrok-free.app/api/mp/webhook

# Allowed origins for local dev
CORS_ORIGIN=http://localhost:5173
