# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Supabase PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres
DATABASE_SSL=true
DATABASE_POOL_MAX=10

# Auth (JWT)
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Storefront URL (for payment return URLs + email links)
FRONTEND_BASE_URL=http://localhost:5173
STORE_NAME=Karolin Active

# Private order link tokens
ORDER_TOKEN_TTL_GUEST_DAYS=90
ORDER_TOKEN_TTL_ACCOUNT_DAYS=0
ORDER_TOKEN_MAX_ACTIVE=5

# Admin notifications
ADMIN_NOTIFY_EMAILS=

# Password reset
RESET_TOKEN_TTL_MINUTES=30

# MercadoPago (optional)
MP_ACCESS_TOKEN=
MP_WEBHOOK_URL=
MP_USE_SANDBOX=true

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Karolin Active <no-reply@example.com>"
TEST_EMAIL_TO=

# Branding email
EMAIL_BRAND_NAME=Karolin Active
EMAIL_BRAND_COLOR=#111111
EMAIL_LOGO_URL=
EMAIL_LOGO_PATH=
EMAIL_LOGO_CID=brandlogo@karolina
EMAIL_SUPPORT=
